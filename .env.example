# Copy this file to .env and fill in your values.
# Environment variables override the config file.

# Telegram
TDMCLAW_TELEGRAM_BOT_TOKEN=your-bot-token-here

# Google OAuth
TDMCLAW_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
TDMCLAW_GOOGLE_CLIENT_SECRET=your-client-secret

# Model provider (if using an API key)
TDMCLAW_MODELS_API_KEY=

# Log level: debug | info | warn | error
TDMCLAW_APP_LOG_LEVEL=info
