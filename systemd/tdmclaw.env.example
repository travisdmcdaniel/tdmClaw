# tdmClaw environment file template
# Copy to /etc/tdmclaw/tdmclaw.env and fill in your values.
# All variables are optional unless noted as REQUIRED.

# ---------------------------------------------------------------------------
# Telegram
# ---------------------------------------------------------------------------

# REQUIRED — Bot token from @BotFather
TDMCLAW_TELEGRAM_BOT_TOKEN=

# ---------------------------------------------------------------------------
# Models (optional overrides for values set in config.yaml)
# ---------------------------------------------------------------------------

# API key for the model provider (leave blank for Ollama)
# TDMCLAW_MODELS_API_KEY=

# ---------------------------------------------------------------------------
# Config path (optional)
# ---------------------------------------------------------------------------

# Override the default config file location (default: /opt/tdmclaw/config/config.yaml)
# TDMCLAW_CONFIG_PATH=/etc/tdmclaw/config.yaml

# ---------------------------------------------------------------------------
# Node.js
# ---------------------------------------------------------------------------

NODE_ENV=production
